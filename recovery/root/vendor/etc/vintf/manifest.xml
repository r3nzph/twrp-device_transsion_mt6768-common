<!--
    VINTF manifest for TWRP Recovery — TECNO Spark 20 (KJ5 / MT6768)
    Android 13 — Trustonic TEE — FBE v2 + metadata encryption

    ONLY recovery-essential HALs are registered here:
    - android.hardware.keymaster @4.1   FBE key derivation (required)
    - android.hardware.gatekeeper @1.0  PIN/password verification (required)
    - vendor.trustonic.tee @1.1         Trustonic TEE base service (required)
    - vendor.trustonic.tee.tui @1.0     Trustonic TUI (required by TEE)
    - android.hardware.boot @1.0        Slot selection for A/B (required)
    - android.hardware.health @2.1      Battery state monitoring (recommended)
    - vendor.mediatek.hardware          MTK keymaster attestation (required)
      .keymaster_attestation @1.1
-->
<manifest version="4.0" type="device" target-level="5">
    <!-- ============================================================
         KEYMASTER 4.1 — FBE key derivation
         Service:  /vendor/bin/hw/android.hardware.keymaster@4.1-service.trustonic
         Required: YES — without this, FBE decryption will fail
         ============================================================ -->
    <hal format="hidl">
        <name>android.hardware.keymaster</name>
        <transport>hwbinder</transport>
        <version>4.1</version>
        <interface>
            <name>IKeymasterDevice</name>
            <instance>default</instance>
        </interface>
        <fqname>@4.1::IKeymasterDevice/default</fqname>
    </hal>

    <!-- ============================================================
         GATEKEEPER 1.0 — PIN/password/pattern verification
         Service:  /vendor/bin/hw/android.hardware.gatekeeper@1.0-service
         Required: YES — TWRP prompts for password before decrypt
         ============================================================ -->
    <hal format="hidl">
        <name>android.hardware.gatekeeper</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>IGatekeeper</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::IGatekeeper/default</fqname>
    </hal>

    <!-- ============================================================
         TRUSTONIC TEE 1.1 — Trusted Execution Environment
         Service:  /vendor/bin/hw/vendor.trustonic.tee@1.1-service
         Required: YES — keymaster & gatekeeper depend on TEE
         ============================================================ -->
    <hal format="hidl">
        <name>vendor.trustonic.tee</name>
        <transport>hwbinder</transport>
        <version>1.1</version>
        <interface>
            <name>ITee</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.1::ITee/default</fqname>
    </hal>

    <!-- ============================================================
         TRUSTONIC TEE TUI 1.0 — Trusted User Interface
         Required: YES — TEE stack requires TUI service
         ============================================================ -->
    <hal format="hidl">
        <name>vendor.trustonic.tee.tui</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>ITui</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::ITui/default</fqname>
    </hal>

    <!-- ============================================================
         BOOT CONTROL 1.0 — A/B slot selection
         Service:  /vendor/bin/hw/android.hardware.boot@1.2-service
                   OR built from source at bootctrl/
         Required: YES — needed for Virtual A/B OTA updates
         ============================================================ -->
    <hal format="hidl">
        <name>android.hardware.boot</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>IBootControl</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::IBootControl/default</fqname>
    </hal>

    <!-- ============================================================
         HEALTH 2.1 — Battery/charger monitoring
         Service:  /vendor/bin/hw/android.hardware.health@2.1-service
         Required: RECOMMENDED — shows battery level in TWRP UI
         ============================================================ -->
    <hal format="hidl">
        <name>android.hardware.health</name>
        <transport>hwbinder</transport>
        <version>2.1</version>
        <interface>
            <name>IHealth</name>
            <instance>default</instance>
        </interface>
        <fqname>@2.1::IHealth/default</fqname>
    </hal>

    <!-- ============================================================
         MTK KEYMASTER ATTESTATION 1.1
         Required: YES — MTK-specific keymaster extension for FBE
         ============================================================ -->
    <hal format="hidl">
        <name>vendor.mediatek.hardware.keymaster_attestation</name>
        <transport>hwbinder</transport>
        <version>1.1</version>
        <interface>
            <name>IKeymasterDevice</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.1::IKeymasterDevice/default</fqname>
    </hal>

    <sepolicy>
        <version>31.0</version>
    </sepolicy>
    <kernel target-level="5"/>
</manifest>
