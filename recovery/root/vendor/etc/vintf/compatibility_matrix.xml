<!--
    VINTF compatibility matrix for TWRP Recovery — TECNO Spark 20 (KJ5 / MT6768)
    Android 13 — Trustonic TEE — FBE v2 + metadata encryption

    Extracted from stock firmware dump. Only HALs relevant to recovery
    are included here. The system-side compatibility requirements (radio,
    sensors, camera, etc.) are omitted as they are not needed in recovery.
-->
<compatibility-matrix version="4.0" type="device">
    <!-- ============================================================
         KEYMASTER 4.1 — FBE key derivation
         Required: YES — recovery cannot decrypt /data without it
         ============================================================ -->
    <hal format="hidl" optional="false">
        <name>android.hardware.keymaster</name>
        <version>4.1</version>
    </hal>

    <!-- ============================================================
         GATEKEEPER 1.0 — PIN/password/pattern verification
         Required: YES — TWRP prompts for credentials before decrypt
         ============================================================ -->
    <hal format="hidl" optional="false">
        <name>android.hardware.gatekeeper</name>
        <version>1.0</version>
    </hal>

    <!-- ============================================================
         TRUSTONIC TEE 1.1 — Trusted Execution Environment base
         Required: YES — keymaster & gatekeeper depend on TEE
         ============================================================ -->
    <hal format="hidl" optional="false">
        <name>vendor.trustonic.tee</name>
        <version>1.1</version>
    </hal>

    <!-- ============================================================
         TRUSTONIC TEE TUI 1.0 — Trusted User Interface
         Required: YES — TEE stack requires TUI for secure I/O
         ============================================================ -->
    <hal format="hidl" optional="false">
        <name>vendor.trustonic.tee.tui</name>
        <version>1.0</version>
    </hal>

    <!-- ============================================================
         BOOT CONTROL 1.0 — A/B slot selection
         Required: YES — needed for Virtual A/B OTA updates
         ============================================================ -->
    <hal format="hidl" optional="false">
        <name>android.hardware.boot</name>
        <version>1.0</version>
    </hal>

    <!-- ============================================================
         HEALTH 2.1 — Battery/charger monitoring
         Required: RECOMMENDED — shows battery level in TWRP UI
         ============================================================ -->
    <hal format="hidl" optional="true">
        <name>android.hardware.health</name>
        <version>2.1</version>
    </hal>

    <!-- ============================================================
         MTK KEYMASTER ATTESTATION 1.1
         Required: YES — MTK-specific extension for FBE
         ============================================================ -->
    <hal format="hidl" optional="false">
        <name>vendor.mediatek.hardware.keymaster_attestation</name>
        <version>1.1</version>
    </hal>

    <!-- ============================================================
         HIDL CORE — Required by all HIDL-based service communication
         ============================================================ -->
    <hal format="hidl" optional="false">
        <name>android.hidl.manager</name>
        <version>1.0</version>
    </hal>
    <hal format="hidl" optional="false">
        <name>android.hidl.memory</name>
        <version>1.0</version>
    </hal>
    <hal format="hidl" optional="false">
        <name>android.hidl.token</name>
        <version>1.0</version>
    </hal>
    <hal format="hidl" optional="false">
        <name>android.hidl.allocator</name>
        <version>1.0</version>
    </hal>

    <vendor-ndk>
        <version>31</version>
    </vendor-ndk>
    <system-sdk>
        <version>31</version>
    </system-sdk>
</compatibility-matrix>
