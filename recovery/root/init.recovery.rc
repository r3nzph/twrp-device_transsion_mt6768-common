# init.recovery.rc - TWRP Recovery Initialization
# MT6768 Common Tree - Android 13
#
# This file provides the generic TWRP init services that are needed
# for HAL-based decryption. Device-specific init is in
# init.recovery.mt6768.rc
#
# Key services defined here:
#   - servicemanager: Routes binder service lookups (required for HALs)
#   - hwservicemanager: Routes HIDL service lookups (required for keymaster/gatekeeper)
#   - vold: Volume daemon for FBE decryption


on early-init
    # Ensure critical /dev nodes exist
    mkdir /dev/block 0755 root root


on init
    # Create necessary directories for TWRP
    mkdir /tmp 0777 root root


on fs
    mount tmpfs tmpfs /tmp
    mkdir /tmp/misc 0777 root root

    # Load precompiled SELinux policy from vendor partition
    # This policy is extracted from the stock ROM's vendor/etc/selinux/
    # and includes rules for Trustonic TEE, keymaster 4.1, gatekeeper,
    # and all MTK platform services. Without the stock policy, vendor
    # HAL services may fail context transitions or be killed by SELinux.
    load_policy /vendor/etc/selinux/precompiled_sepolicy

    # Apply vendor file contexts to critical paths so that files
    # restored from backups or mounted partitions get the correct
    # SELinux labels expected by the vendor services.
    restorecon --recursive /vendor/bin
    restorecon --recursive /vendor/lib64
    restorecon --recursive /vendor/etc
    restorecon /vendor

    # Set SELinux to permissive for recovery
    # Despite having the stock policy loaded, TWRP's custom service
    # labels (u:r:recovery:s0, u:r:adbd:s0) may not be in the stock
    # policy. Permissive mode allows these to still function while
    # the stock policy provides context definitions for restorecon
    # and service labeling.
    setenforce 0


# ============================================================
# SERVICE MANAGER
# ============================================================
# Required by: All binder-based HAL services

service servicemanager /system/bin/servicemanager
    class core
    user system
    group system readproc
    critical
    onrestart restart healthd
    onrestart restart zygote
    onrestart restart audioserver
    onrestart restart media
    onrestart restart surfaceflinger
    onrestart restart inputflinger
    onrestart restart drm
    onrestart restart cameraserver
    onrestart restart keystore
    onrestart restart gatekeeperd
    onrestart restart servicemanager
    seclabel u:r:servicemanager:s0
    disabled


# ============================================================
# HW SERVICE MANAGER
# ============================================================
# Required by: All HIDL-based vendor HAL services
# (keymaster, gatekeeper, tee, boot control, health)
# Sets hwservicemanager.ready=true after registration

service hwservicemanager /system/bin/hwservicemanager
    class core
    user system
    group system readproc
    critical
    onrestart restart hwservicemanager
    seclabel u:r:hwservicemanager:s0
    disabled


# ============================================================
# ADBD (ADB DAEMON)
# ============================================================

service adbd /system/bin/adbd --root_seclabel=u:r:adbd:s0
    class core
    socket adbd stream 660 system system
    seclabel u:r:adbd:s0
    disabled
    oneshot


# ============================================================
# VOLD (VOLUME DAEMON)
# ============================================================
# Required for: FBE decryption via TW_CRYPTO_USE_SYSTEM_VOLD
# vold handles /data mount/unlock with the key from keymaster.
#
# NOTE: vold is DISABLED and NOT started at boot. TWRP starts
# vold when the user needs to decrypt via ctl.start property.
# Removing oneshot ensures vold stays running once started.

service vold /system/bin/vold --blkid_prefixes=/dev/block/
    class core
    user root
    group root system
    disabled
    shutdown critical
    seclabel u:r:vold:s0


# ============================================================
# LOW MEMORY KILLER (required by some AOSP components)
# ============================================================

service lmkd /system/bin/lmkd
    class main
    user root
    group root readproc
    disabled
    oneshot
    seclabel u:r:lmkd:s0


# ============================================================
# BOOT HAL SERVICE INITIALIZATION TRIGGER
# ============================================================
# Start hwservicemanager and servicemanager early so that
# the TEE stack (mobicore → tee-1-1 → keymaster → gatekeeper)
# can register their HIDL services.

on boot
    start servicemanager
    start hwservicemanager

    # Wait for hwservicemanager to register before starting TEE stack.
    # The hwservicemanager sets hwservicemanager.ready=true after init.
    # TEE stack start is handled in init.recovery.mt6768.rc via:
    #   on property:hwservicemanager.ready=true

    # NOTE: vold is NOT started here. TWRP starts vold on-demand
    # when the user attempts FBE decryption via ctl.start=vold.
    # This ensures keymaster + gatekeeper are already initialized
    # before vold attempts to derive keys.
