# 07060000000000000000000000007169.drbin : MtkH264Vdec
# 08070000000000000000000000008270.drbin : MtkVP9Vdec
# 5020170115e016302017012521300000.drbin : drm_hdcp_common
# 40188311faf343488db888ad39496f9a.drbin : widevine
# 06090000000000000000000000000000.drbin : drm keyinstall
# 9073f03a9618383bb1856eb3f990babd.drbin : m4u
#
# Files REFERENCED in stock trustonic.rc but NOT present in dump:
# 05160000000000000000000000000000.drbin (unnamed)
# 03100000000000000000000000000000.drbin (unnamed)
# 031c0000000000000000000000000000.drbin (unnamed)
# 032c0000000000000000000000000000.drbin (unnamed)
# 033c0000000000000000000000000000.drbin (unnamed)
# 034c0000000000000000000000000000.drbin (unnamed)
# 035c0000000000000000000000000000.drbin (unnamed)
# 036c0000000000000000000000000000.drbin (unnamed)
# 037c0000000000000000000000000000.drbin (unnamed)
# 090b0000000000000000000000000000.drbin : IRIS_I2C
# 0f5eed3c3b5a47afacca69a84bf0efad.drbin : isp
# 4be4f7dc1f2c11e5b5f7727283247c7f.drbin : MtkH265Vdec
# 07407000000000000000000000000000.drbin : sensor
# 07090000000000000000000000000000.drbin (unnamed)
# 6b3f5fa0f8cf55a7be2582587d62d63a.drbin : hdcp


# ============================================================
# TRUSTONIC TEE 1.1 HAL SERVICE
# ============================================================
# Source: vendor/etc/init/vendor.trustonic.tee@1.1-service.rc (KJ5 firmware dump)
# Binary: /vendor/bin/hw/vendor.trustonic.tee@1.1-service
#   PATH VERIFIED: recovery/root/vendor/bin/hw/vendor.trustonic.tee@1.1-service (73552 bytes)

service tee-1-1 /vendor/bin/hw/vendor.trustonic.tee@1.1-service
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0


# ============================================================
# KEYMASTER 4.1 - TRUSTONIC BACKEND
# ============================================================
# Source: vendor/etc/init/android.hardware.keymaster@4.1-service.trustonic.rc (KJ5 firmware dump)
# Binary: /vendor/bin/hw/android.hardware.keymaster@4.1-service.trustonic
#   PATH VERIFIED: recovery/root/vendor/bin/hw/android.hardware.keymaster@4.1-service.trustonic (97824 bytes)

service vendor.keymaster-4-1-trustonic /vendor/bin/hw/android.hardware.keymaster@4.1-service.trustonic
    class early_hal
    user system
    group system drmrpc
    disabled
    seclabel u:r:recovery:s0


# ============================================================
# KEYMASTER ATTESTATION 1.1 - MEDIATEK
# ============================================================
# Source: vendor/etc/init/vendor.mediatek.hardware.keymaster_attestation@1.1-service.rc (KJ5 firmware dump)
# Binary: /vendor/bin/hw/vendor.mediatek.hardware.keymaster_attestation@1.1-service
#   PATH VERIFIED: recovery/root/vendor/bin/hw/vendor.mediatek.hardware.keymaster_attestation@1.1-service (11128 bytes)

service keymaster_attestation-1-1 /vendor/bin/hw/vendor.mediatek.hardware.keymaster_attestation@1.1-service
    interface vendor.mediatek.hardware.keymaster_attestation@1.0::IKeymasterDevice default
    interface vendor.mediatek.hardware.keymaster_attestation@1.1::IKeymasterDevice default
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0


# ============================================================
# GATEKEEPER 1.0 HAL SERVICE
# ============================================================
# Source: vendor/etc/init/android.hardware.gatekeeper@1.0-service.rc (KJ5 firmware dump)
# Binary: /vendor/bin/hw/android.hardware.gatekeeper@1.0-service
#   PATH VERIFIED: recovery/root/vendor/bin/hw/android.hardware.gatekeeper@1.0-service (11160 bytes)

service vendor.gatekeeper-1-0 /vendor/bin/hw/android.hardware.gatekeeper@1.0-service
    interface android.hardware.gatekeeper@1.0::IGatekeeper default
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0


# ============================================================
# TRUSTONIC KEYBOX CHECK SERVICE
# ============================================================
# Source: vendor/etc/init/trustonic.mc_kmsetkey_ca.rc (KJ5 firmware dump)
# Binary: /vendor/bin/kmsetkey_ca.trustonic -c
#   PATH VERIFIED: recovery/root/vendor/bin/kmsetkey_ca.trustonic (19440 bytes)

service trustonic_check_keybox_service /vendor/bin/kmsetkey_ca.trustonic -c
    class late_start
    user system
    group system
    oneshot
    disabled
    seclabel u:r:recovery:s0


# ============================================================
# TEE STARTUP SEQUENCE
# ============================================================
# Correct startup order:
#   1. mobicore (mcDriverDaemon) - initializes TEE hardware
#   2. tee-1-1 - registers TEE HAL interface
#   3. vendor.keymaster-4-1-trustonic - registers keymaster HAL
#   4. vendor.gatekeeper-1-0 - registers gatekeeper HAL
#
# Triggered when hwservicemanager.ready=true (set by hwservicemanager).

on property:hwservicemanager.ready=true
    # Start TEE stack in dependency order
    start mobicore
    start tee-1-1
    start vendor.keymaster-4-1-trustonic
    start vendor.gatekeeper-1-0
    # Keybox check (kmsetkey_ca.trustonic) - not critical for FBE
    # In stock ROM this is class late_start, started unconditionally
    start trustonic_check_keybox_service


# ============================================================
# CLEANUP TRIGGERS
# ============================================================

on property:ro.crypto.state=unsupported
    stop mobicore
    stop tee-1-1
    stop vendor.keymaster-4-1-trustonic
    stop vendor.gatekeeper-1-0
    stop trustonic_check_keybox_service

on property:twrp.decrypt.done=true && property:twrp.all.users.decrypted=true
    write /proc/bootprof "TWRP: decryption done, stopping TEE services"
    stop mobicore
    stop tee-1-1
    stop vendor.keymaster-4-1-trustonic
    stop vendor.gatekeeper-1-0
    stop trustonic_check_keybox_service
