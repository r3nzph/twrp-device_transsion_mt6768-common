# init.tee.rc - Trustonic TEE / Mobicore / Keymaster / Gatekeeper
# TECNO Spark 20 (KJ5 / MT6768) - Android 13
#
# GENERATED EXCLUSIVELY FROM TECNO KJ5 FIRMWARE DUMP
# Source: dumps.tadiphone.dev/dumps/tecno/tecno-kj5.git
#
# ALL PATHS VERIFIED against recovery/root/vendor/:
#    6 service binaries       ✓ all exist
#   14 .drbin files           ✓ all exist in vendor/app/mcRegistry/
#   15 .drbin files removed   ✗ referenced in stock trustonic.rc but not present in dump
#
# Consolidated from:
#   vendor/etc/init/tee.rc                          - Directory setup
#   vendor/etc/init/trustonic.rc                    - mobicore (mcDriverDaemon) + .drbin registrations
#   vendor/etc/init/trustonic.mc_kmsetkey_ca.rc     - trustonic_check_keybox_service
#   vendor/etc/init/vendor.trustonic.tee@1.1-service.rc  - tee-1-1 HAL service
#   vendor/etc/init/android.hardware.keymaster@4.1-service.trustonic.rc  - keymaster 4.1
#   vendor/etc/init/vendor.mediatek.hardware.keymaster_attestation@1.1-service.rc  - attestation
#   vendor/etc/init/android.hardware.gatekeeper@1.0-service.rc  - gatekeeper
#
# This device uses Trustonic Kinibi TEE (not Microtrust/TEEI, not beanpod).
# mcDriverDaemon is the TEE daemon (service name "mobicore").
#
# NOTE: This file must be imported from init.recovery.mt6768.rc
# Add:  import /init.tee.rc
# Then remove duplicate TEE service definitions from init.recovery.mt6768.rc.


# ============================================================
# TEE DIRECTORIES & PERMISSIONS
# ============================================================
# Source: vendor/etc/init/tee.rc (KJ5 firmware dump, verbatim)

on init
    # Create mountpoint for /mnt/vendor/persist partition
    # (matches stock vendor/etc/init/tee.rc trigger)
    mkdir /mnt/vendor/persist 0771 system system

on post-fs
    chown system system /mnt/vendor/persist
    chmod 0771 /mnt/vendor/persist

    # Apply SELinux label to persist mount point
    restorecon /mnt/vendor/persist

    # mcRegistry directory - stores TEE failure records and trusted app registry
    mkdir /mnt/vendor/persist/mcRegistry 0771 system system

    # paytrigger - used by pay/DRM trigger mechanisms
    mkdir /mnt/vendor/persist/paytrigger
    chown system system /mnt/vendor/persist/paytrigger
    chmod 0777 /mnt/vendor/persist/paytrigger

    # startPara - anti-crack parameter storage per BSP xiaolin.wu 20231225
    mkdir /mnt/vendor/persist/startPara
    chown system system /mnt/vendor/persist/startPara
    chmod 0777 /mnt/vendor/persist/startPara
    mkdir /tranfs/startPara
    chown system system /tranfs/startPara
    chmod 0777 /tranfs/startPara

on post-fs-data
    # Key provisioning directory - stores provisioned key blobs
    mkdir /data/vendor/key_provisioning 0771 system system


# ============================================================
# CRYPTO STATE TRIGGERS - /data/vendor/mcRegistry Creation
# ============================================================
# Source: vendor/etc/init/tee.rc (KJ5 firmware dump, verbatim)

# META/FACTORY mode - unencrypted device
on property:ro.crypto.state=unencrypted
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry ++ (unencrypted)"
    mkdir /data/vendor/mcRegistry 0775 system system
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry -- (unencrypted)"

# Normal mode with FBE
on property:ro.crypto.type=file && property:ro.crypto.state=encrypted
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry ++ (FBE encrypted)"
    mkdir /data/vendor/mcRegistry 0775 system system
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry -- (FBE encrypted)"

# Normal mode with FDE
on property:vold.decrypt=trigger_restart_framework
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry ++ (FDE encrypted)"
    mkdir /data/vendor/mcRegistry 0775 system system
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry -- (FDE encrypted)"


# ============================================================
# MOBICORE SERVICE (mcDriverDaemon)
# ============================================================
# Source: vendor/etc/init/trustonic.rc (KJ5 firmware dump, verbatim)
# Daemon: /vendor/bin/mcDriverDaemon
#   PATH VERIFIED: recovery/root/vendor/bin/mcDriverDaemon (732504 bytes)
#
# This is the Trustonic TEE driver daemon. Despite the service name
# "mobicore", the actual binary is mcDriverDaemon (Kinibi TEE).
#
# Only .drbin files that exist in recovery/root/vendor/app/mcRegistry/
# are included below. The stock trustonic.rc references 29 .drbin files,
# but 15 of those have no corresponding file in the firmware dump's
# mcRegistry directory and have been excluded here. mcDriverDaemon
# tolerates missing -r entries gracefully (logs warning, continues).
#
# See t-Drv naming comments at end of file.

service mobicore /vendor/bin/mcDriverDaemon \
    --sfs-reformat --P1 /mnt/vendor/persist/mcRegistry \
    -r /vendor/app/mcRegistry/06090000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/020f0000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/05120000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/05120000000000000000000000000001.drbin \
    -r /vendor/app/mcRegistry/020b0000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/05070000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/030b0000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/030c0000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/40188311faf343488db888ad39496f9a.drbin \
    -r /vendor/app/mcRegistry/07060000000000000000000000007169.drbin \
    -r /vendor/app/mcRegistry/08070000000000000000000000008270.drbin \
    -r /vendor/app/mcRegistry/07070000000000000000000000000000.drbin \
    -r /vendor/app/mcRegistry/9073f03a9618383bb1856eb3f990babd.drbin \
    -r /vendor/app/mcRegistry/5020170115e016302017012521300000.drbin
    class core
    user system
    group system
    priority -20
    disabled
    seclabel u:r:recovery:s0

