# ueventd.mt6768.rc
# Device node permissions for TECNO Spark 20 (KJ5 / MT6768)
# Required for: display, touch, TEE, storage, USB, GPIO access

# ============================================================
# DISPLAY / GRAPHICS (DRM)
# ============================================================
/dev/dri/card0                 0660    graphics graphics
/dev/dri/controlD64            0660    graphics graphics
/dev/fb0                       0660    graphics graphics

# ============================================================
# INPUT / TOUCHSCREEN
# ============================================================
/dev/input/*                   0660    root    input

# ============================================================
# TRUSTONIC TEE / SECURE WORLD
# ============================================================
/dev/tee0                      0666    system  system
/dev/teepriv0                  0660    system  system
/dev/tzdev                     0666    system  system
/dev/mobicore                  0666    system  system
/dev/mobicore-user            0666    system  system
/dev/MCD                       0660    system  system
/dev/MCDCDEV                  0660    system  system

# ============================================================
# KEYMASTER / GATEKEEPER
# ============================================================
/dev/km*                       0660    system  system
/dev/gatekeeper*               0660    system  system

# ============================================================
# STORAGE (EMMC / UFS)
# ============================================================
/dev/block/mmcblk0             0660    root    root
/dev/block/mmcblk0boot0        0660    root    root
/dev/block/mmcblk0boot1        0660    root    root
/dev/block/mmcblk0p*           0660    root    root
/dev/block/mmcblk1             0660    root    root
/dev/block/mmcblk1p*           0660    root    root
/dev/block/sd*                 0660    root    root
/dev/block/platform/*          0660    root    root
/dev/block/by-name/*           0660    root    root
/dev/block/mapper/*            0660    root    root
/dev/block/bootdevice/*        0660    root    root

# ============================================================
# USB GADGET / CONFIGFS
# ============================================================
/dev/usb-ffs/*                 0770    shell   shell
/dev/mtp_usb                   0660    mtp     mtp
/config/usb_gadget/*           0770    shell   shell

# ============================================================
# MEDIATEK SPECIFIC HARDWARE
# ============================================================
/dev/mtk_dhcpv4                0660    system  system
/dev/mtk_ftrace                0660    system  system
/dev/mtk_md_cool               0660    system  system
/dev/mtk_md_direct_logger      0660    system  system
/dev/mtk_md_sbp                0660    system  system
/dev/mtk_mem_bridge            0660    system  system
/dev/mtk_mml                   0660    system  graphics
/dev/mtk_wmd                   0660    system  system
/dev/mmdvfs                    0660    system  system

# ============================================================
# BATTERY / POWER / CHARGER
# ============================================================
/dev/charger                   0660    root    root
/dev/oplus_chg                 0660    root    root
/sys/class/power_supply/*      0660    root    root
/sys/class/backlight/*         0660    system  system

# ============================================================
# MISC
# ============================================================
/dev/kmsg                      0660    root    root
/dev/log/*                     0660    root    log
/dev/tty*                      0660    root    root
/dev/ptmx                      0666    root    root
/dev/tun                       0660    vpn     vpn
/dev/uinput                    0660    root    input
/dev/ion                       0666    system  system
/dev/dma_heap/*                0660    system  system
/dev/rpmb                      0660    root    root
/dev/bootprof                  0660    root    root
/dev/mrdump                    0660    root    root
